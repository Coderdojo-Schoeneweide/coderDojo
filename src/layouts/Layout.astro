---
// Simple base layout for all pages
import '@/styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '@/content';
import { resolveLocale } from '@/utils/contentLocalization.ts';

interface Props {
  title?: string;
  description?: string;
}

const { title = siteConfig.title, description = siteConfig.description } =
  Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const dir = locale === 'ar' || locale === 'sa' ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={locale} dir={dir} class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} &ndash; CoderDojo Schöneweide</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
