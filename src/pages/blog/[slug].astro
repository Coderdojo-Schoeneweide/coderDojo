---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { useTranslations } from '@/i18n.ts';
import {
  findLocalizedEntryById,
  getBaseContentId,
  getRouteSlug,
  resolveLocale,
  toAsciiSlug,
} from '@/utils/contentLocalization.ts';

export async function getStaticPaths() {
  const allPosts: CollectionEntry<'blog'>[] = await getCollection('blog');
  const posts: CollectionEntry<'blog'>[] = [];
  for (const post of allPosts) {
    if (!post.data.draft) {
      posts.push(post);
    }
  }
  const seenBaseIds = new Set<string>();

  return posts
    .map((post: CollectionEntry<'blog'>) => ({
      slug: post.slug || getRouteSlug(post.id),
      baseId: getBaseContentId(post.id),
    }))
    .filter(({ baseId }) => {
      if (seenBaseIds.has(baseId)) {
        return false;
      }

      seenBaseIds.add(baseId);
      return true;
    })
    .flatMap(({ slug, baseId }) => {
      const canonicalSlug = toAsciiSlug(slug);
      const slugs =
        canonicalSlug === slug ? [canonicalSlug] : [canonicalSlug, slug];

      return slugs.map((routeSlug) => ({
        params: { slug: routeSlug },
        props: { baseId },
      }));
    });
}

const locale = resolveLocale(Astro.currentLocale);
const { baseId } = Astro.props as { baseId?: string };
const allPosts: CollectionEntry<'blog'>[] = await getCollection('blog');
const posts: CollectionEntry<'blog'>[] = [];
for (const post of allPosts) {
  if (!post.data.draft) {
    posts.push(post);
  }
}
const post = baseId ? findLocalizedEntryById(posts, baseId, locale) : undefined;

if (!post) {
  throw new Error(`Missing blog post content for id: ${baseId}`);
}

const { Content } = await render(post);
const { t, translatePath } = useTranslations(Astro.currentLocale);

const formatDate = (date: Date, currentLocale: string) => {
  const localeTagByLocale: Record<string, string> = {
    de: 'de-DE',
    en: 'en-US',
    ar: 'ar',
  };

  return date.toLocaleDateString(localeTagByLocale[currentLocale] ?? 'de-DE', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="bg-white dark:bg-gray-900">
    <!-- Header -->
    <header class="bg-accent-dark py-16 text-white">
      <div class="container mx-auto px-6">
        <div class="mx-auto max-w-3xl">
          <a
            href={translatePath('/blog')}
            class="mb-6 inline-flex items-center text-sm text-gray-300 transition-colors hover:text-white"
          >
            <svg
              class="mr-2 h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"
              >
              </path>
            </svg>
            {t('blog.back')}
          </a>

          <h1 class="mb-4 text-3xl font-bold md:text-4xl lg:text-5xl">
            {post.data.title}
          </h1>

          <div class="flex flex-wrap items-center gap-4 text-gray-300">
            <time datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date, locale)}
            </time>

            {
              post.data.authors && post.data.authors.length > 0 && (
                <>
                  <span>•</span>
                  <span>
                    {t('blog.by')} {post.data.authors.join(', ')}
                  </span>
                </>
              )
            }
          </div>

          {
            post.data.categories && post.data.categories.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-2">
                {post.data.categories.map((category: string) => (
                  <span class="inline-block rounded-full bg-white/20 px-3 py-1 text-sm capitalize">
                    {category}
                  </span>
                ))}
              </div>
            )
          }
        </div>
      </div>
    </header>

    <!-- Content -->
    <div class="py-12">
      <div class="container mx-auto px-6">
        <div
          class="prose prose-lg dark:prose-invert prose-headings:text-accent-900 dark:prose-headings:text-white prose-p:text-gray-700 dark:prose-p:text-gray-300 prose-a:text-primary-600 dark:prose-a:text-primary-400 mx-auto max-w-3xl"
        >
          <Content />
        </div>
      </div>
    </div>

    <!-- Footer Navigation -->
    <footer class="border-t border-gray-200 py-8 dark:border-gray-700">
      <div class="container mx-auto px-6">
        <div class="mx-auto max-w-3xl">
          <a
            href={translatePath('/blog')}
            class="text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 inline-flex items-center transition-colors"
          >
            <svg
              class="mr-2 h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"
              >
              </path>
            </svg>
            {t('blog.all-posts')}
          </a>
        </div>
      </div>
    </footer>
  </article>
</Layout>
