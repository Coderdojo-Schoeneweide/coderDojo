---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WorkshopGridIsland from '../components/islands/WorkshopGridIsland.jsx';
import { getCollection } from 'astro:content';
import {
  getBaseContentId,
  resolveLocale,
  selectLocalizedEntries,
} from '@/utils/contentLocalization.ts';

const locale = resolveLocale(Astro.currentLocale);

const workshopsPageEntries = import.meta.glob<{
  frontmatter: { title: string; background?: 'light' | 'dark' | 'accent' };
  Content: any;
}>('../content/workshops/**/index.md');
const workshopsPagePath =
  `../content/workshops/${locale}/index.md` in workshopsPageEntries ?
    `../content/workshops/${locale}/index.md`
  : '../content/workshops/index.md';
const loadWorkshopsPageModule = workshopsPageEntries[workshopsPagePath];
const workshopsPageModule = await loadWorkshopsPageModule();
const workshopsPageFrontmatter = workshopsPageModule.frontmatter;
const WorkshopsPageContent = workshopsPageModule.Content;

// Get all workshops and keep locale-specific variants with fallback.
const allWorkshops = await getCollection('workshops');
const workshops = selectLocalizedEntries(allWorkshops, locale);
workshops.sort((a: any, b: any) => {
  const weightA = a.data.weight ?? Number.POSITIVE_INFINITY;
  const weightB = b.data.weight ?? Number.POSITIVE_INFINITY;
  if (weightA !== weightB) return weightA - weightB;
  return a.data.title.localeCompare(b.data.title);
});

// Transform workshops data for the island component
const workshopsData = workshops.map((workshop: any) => ({
  id: getBaseContentId(workshop.id),
  title: workshop.data.title,
  description: workshop.data.description,
  duration: workshop.data.duration,
  age: workshop.data.age,
  tags: workshop.data.tags,
  image: `/workshops/${getBaseContentId(workshop.id)}/${workshop.data.image}`,
  prevKnowledge: workshop.data.prevKnowledge || 'Nicht angegeben',
  content: workshop.body, // Markdown content
  folder: getBaseContentId(workshop.id), // For the modal system
}));
---

<Layout
  title={workshopsPageFrontmatter.title}
  description="Entdecke unsere kostenlosen IT-Workshops für Kinder und Jugendliche. Von Scratch bis Python - hier lernst du spielerisch programmieren!"
>
  <Hero
    hero={{
      title: workshopsPageFrontmatter.title,
      background: (workshopsPageFrontmatter.background || 'light') as
        | 'light'
        | 'dark'
        | 'accent',
    }}
  >
    <WorkshopsPageContent />
  </Hero>

  <!-- Workshop Grid Section -->
  <section
    class="text-accent-900 bg-white py-20 dark:bg-gray-900 dark:text-gray-100"
  >
    <div class="container mx-auto px-6">
      <WorkshopGridIsland workshops={workshopsData} client:load />
    </div>
  </section>
</Layout>
