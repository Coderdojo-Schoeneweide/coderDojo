---
// Verein Page - Content-driven
import { readdir } from 'node:fs/promises';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { getCollection, render } from 'astro:content';
import { findLocalizedEntryById } from '@/utils/contentLocalization.ts';

const pages = await getCollection('pages');
const page = findLocalizedEntryById(pages, 'verein', Astro.currentLocale);

if (!page) {
  throw new Error('Missing page content: verein');
}

const { Content } = await render(page);

const reportsRoot = 'public/Jahresberichte/';
const reports = (await readdir(reportsRoot))
  .sort((a, b) => a.length - b.length)
  .reduce((map, report) => {
    const parts = report.replace('.pdf', '').split('-');
    const name = parts[0];
    if (!map.has(name)) map.set(name, []);
    map.get(name).push({ file: report, variant: parts[1] });
    return map;
  }, new Map());
---

<Layout title="Verein">
  <Hero hero={page.data}>
    <Content />
  </Hero>
