---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import BlogGridIsland from '../components/islands/BlogGridIsland.jsx';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { useTranslations } from '@/i18n.ts';
import {
  getRouteSlug,
  resolveLocale,
  selectLocalizedEntries,
} from '@/utils/contentLocalization.ts';

const { t, translatePath } = useTranslations(Astro.currentLocale);
const locale = resolveLocale(Astro.currentLocale);

// Get all blog posts, filter out drafts, and sort by date (newest first)
const allPosts: CollectionEntry<'blog'>[] = await getCollection('blog');
const posts = selectLocalizedEntries(
  allPosts.filter((post) => !post.data.draft),
  locale,
);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Helper: extract first image URL from markdown body
// Handles ![alt](url) and ![alt](url "title") patterns
function extractFirstImage(body: string): string | undefined {
  const match = body.match(/!\[.*?\]\((\S+?)(?:\s+"[^"]*")?\)/);
  return match ? match[1] : undefined;
}

// Helper: extract a plain-text preview from markdown body
function extractPreview(body: string, maxLength = 160): string {
  const text = body
    .replace(/!\[.*?\]\(.*?\)/g, '') // remove images
    .replace(/\[([^\]]*)\]\(.*?\)/g, '$1') // links -> text
    .replace(/#{1,6}\s+/g, '') // headings
    .replace(/[*_~`>]/g, '') // formatting chars
    .replace(/\n+/g, ' ') // newlines -> space
    .trim();
  return text.length > maxLength ? text.slice(0, maxLength) + '…' : text;
}

// Transform posts data for the island component
const postsData = posts.map((post) => {
  const image = post.data.image || extractFirstImage(post.body || '');
  const preview = post.data.description || extractPreview(post.body || '');
  return {
    id: post.id,
    slug: post.slug || getRouteSlug(post.id),
    title: post.data.title,
    description: preview,
    date: post.data.date.toISOString(),
    categories: post.data.categories || [],
    tags: post.data.tags || [],
    authors: post.data.authors || [],
    image,
  };
});
---

<Layout
  title={t('blog.overview.title')}
  description={t('blog.overview.description').replace('{{title}}', t('title'))}
>
  <Hero
    hero={{
      title: t('blog.overview.title'),
      background: 'accent',
    }}
  >
    <p>
      {t('blog.overview.description').replace('{{title}}', t('title'))}
    </p>
  </Hero>

  <!-- Blog Grid Section -->
  <section
    class="text-accent-900 bg-white py-20 dark:bg-gray-900 dark:text-gray-100"
  >
    <div class="container mx-auto px-6">
      <BlogGridIsland
        posts={postsData}
        blogBasePath={translatePath('/blog')}
        client:load
      />
    </div>
  </section>
</Layout>
