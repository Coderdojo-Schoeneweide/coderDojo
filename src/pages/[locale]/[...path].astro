---
import '@/styles/global.css';
import { configuration, type Locale } from '@/i18n.ts';
import NotFoundPage from '../404.astro';

// Dynamic component imports using glob
const pages = import.meta.glob('../*.astro', { eager: true });
const markdownPages = import.meta.glob('../*.md', { eager: true });
const blogPages = import.meta.glob('../blog/*.astro', { eager: true });

type RouteComponent = any;

// Build route map from dynamic imports
const createRouteMap = (): Record<string, RouteComponent> => {
  const routeMap: Record<string, RouteComponent> = {
    '': pages['../index.astro']?.default,
    accessibility: pages['../accessibility.astro']?.default,
    blog: pages['../blog.astro']?.default,
    collaborations: pages['../collaborations.astro']?.default,
    datenschutz: pages['../datenschutz.astro']?.default,
    donate: pages['../donate.astro']?.default,
    imprint: pages['../imprint.astro']?.default,
    jahresberichte: pages['../jahresberichte.astro']?.default,
    mentoring: pages['../mentoring.astro']?.default,
    newsletter: pages['../newsletter.astro']?.default,
    'privacy-policy': markdownPages['../privacy-policy.md']?.default,
    reports: pages['../jahresberichte.astro']?.default,
    society: pages['../society.astro']?.default,
    verein: pages['../verein.astro']?.default,
    'supporting-membership': pages['../supporting-membership.astro']?.default,
    workshops: pages['../workshops.astro']?.default,
  };

  return Object.fromEntries(
    Object.entries(routeMap).filter(([_, value]) => value !== undefined),
  );
};

const staticRouteMap = createRouteMap();

const supportedLocalizedLocales = configuration.locales.filter(
  (locale) => locale !== configuration.defaultLocale,
);

export async function getStaticPaths() {
  // Dynamic blog import
  const { getStaticPaths: getBlogStaticPaths } =
    await import('../blog/[slug].astro');

  const localizedLocales = configuration.locales.filter(
    (locale) => locale !== configuration.defaultLocale,
  );
  const staticPathsForLocalizedPages = [
    '',
    'accessibility',
    'collaborations',
    'datenschutz',
    'donate',
    'imprint',
    'jahresberichte',
    'mentoring',
    'newsletter',
    'privacy-policy',
    'reports',
    'society',
    'verein',
    'supporting-membership',
    'workshops',
  ];

  const localizedPagePaths = localizedLocales.flatMap((locale) =>
    staticPathsForLocalizedPages.map((path) => ({
      params: {
        locale,
        path: path || undefined,
      },
    })),
  );

  const localizedBlogIndexPaths = localizedLocales.map((locale) => ({
    params: {
      locale,
      path: 'blog',
    },
  }));

  const blogPostPaths = await getBlogStaticPaths();
  const localizedBlogPostPaths = localizedLocales.flatMap((locale) =>
    blogPostPaths.map((blogPath) => ({
      params: {
        locale,
        path: `blog/${blogPath.params.slug}`,
      },
      props: blogPath.props,
    })),
  );

  return [
    ...localizedPagePaths,
    ...localizedBlogIndexPaths,
    ...localizedBlogPostPaths,
  ];
}

const localeParam = Astro.params.locale as Locale | undefined;
if (!localeParam || !supportedLocalizedLocales.includes(localeParam)) {
  throw new Error(`Unsupported locale route: ${localeParam}`);
}

const normalizedPath = (Astro.params.path ?? '').replace(/^\/+|\/+$/g, '');
const isBlogIndex = normalizedPath === 'blog';
const isBlogPost = normalizedPath.startsWith('blog/');

const BlogIndexPage = pages['../blog.astro']?.default;
const BlogPostPage = blogPages['../blog/[slug].astro']?.default;
const RoutePage = staticRouteMap[normalizedPath] ?? NotFoundPage;
---

{isBlogIndex && <BlogIndexPage />}

{isBlogPost && <BlogPostPage {...Astro.props} />}

{!isBlogIndex && !isBlogPost && <RoutePage />}
