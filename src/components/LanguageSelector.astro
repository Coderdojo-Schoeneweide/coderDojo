---
import { Picture } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { configuration, useTranslations } from '@/i18n.ts';

interface Props {
  variant?: 'dropdown' | 'inline';
}

const { variant = 'dropdown' } = Astro.props;

const icons = Object.fromEntries(
  await Promise.all(
    Object.entries(
      import.meta.glob<{ default: any }>('/src/assets/locales/*.svg'),
    ).map(async ([path, image]) => [path.match(/\/([a-z]+)\./)![1], image()]),
  ),
);

const { t } = useTranslations(Astro.currentLocale);
const localePrefixPattern = new RegExp(
  `^/(?:${configuration.locales.join('|')})(?=/|$)`,
);
const currentPath = Astro.url.pathname || '/';
const unlocalizedPath =
  (currentPath.replace(localePrefixPattern, '') || '/').replace(/\/+$/, '') ||
  '/';
const canonicalPath = unlocalizedPath === '/' ? '/' : `${unlocalizedPath}/`;

const locales = configuration.locales.map((locale) => ({
  locale,
  link: getRelativeLocaleUrl(locale, canonicalPath),
  label:
    useTranslations(locale).t(`locales.${locale}`) +
    (Astro.currentLocale === locale ? '' : ` (${t(`locales.${locale}`)})`),
  icon: icons[locale],
}));

const navClass =
  variant === 'inline' ?
    'flex flex-wrap gap-2'
  : 'bg-brand flex flex-col gap-2 rounded-b-xl px-5 py-2 font-medium';

const linkClass =
  variant === 'inline' ?
    'border-dark/40 flex items-center gap-2 rounded-md border px-2 py-1 text-sm whitespace-nowrap'
  : 'border-dark flex items-center gap-2 border-b pb-2 whitespace-nowrap first:pt-1 last:border-0 last:pb-1';
---

<nav class={navClass}>
  {
    locales.map(({ locale, link, label, icon }) => (
      <a
        href={link}
        class:list={[
          linkClass,
          variant === 'inline' && Astro.currentLocale === locale ?
            'bg-accent-dark border-accent-dark text-white'
          : '',
        ]}
      >
        <Picture
          src={icon}
          alt={label}
          layout="constrained"
          class="rounded-full"
          pictureAttributes={{ class: 'shrink-0 w-6 h-6' }}
        />
        {label}
      </a>
    ))
  }
</nav>
